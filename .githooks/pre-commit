#!/bin/sh

# Pre-commit hook: run dotnet format on staged .cs files
# to fix IDE0005 (unnecessary usings) and other formatting issues.

echo "=== Pre-commit: Running dotnet format ==="

# Get staged .cs files
STAGED_CS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.cs$' | tr '\n' ' ')

if [ -n "$STAGED_CS_FILES" ]; then
    dotnet format --include "$STAGED_CS_FILES"
    if [ $? -ne 0 ]; then
        echo "WARNING: dotnet format encountered issues on staged files."
    fi

    # Re-stage any files that were modified by dotnet format
    git add $STAGED_CS_FILES
fi

echo "=== Pre-commit: Formatting complete ==="
exit 0
